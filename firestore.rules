rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isCustomer() {
      return isSignedIn() && userDoc(request.auth.uid).data.role == "customer";
    }

    function isShopOwner() {
      return isSignedIn() && userDoc(request.auth.uid).data.role == "shop_owner";
    }

    function shopDoc(shopId) {
      return get(/databases/$(database)/documents/shops/$(shopId));
    }

    function orderDoc(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId));
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /shops/{shopId} {
      allow read: if isSignedIn();
      allow create: if isShopOwner() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isShopOwner() && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        shopDoc(resource.data.shopId).data.ownerId == request.auth.uid
      );
      allow create: if isCustomer() && request.resource.data.customerId == request.auth.uid;
      allow update: if isShopOwner() &&
        shopDoc(resource.data.shopId).data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /order_files/{fileId} {
      allow read: if isSignedIn() && (
        orderDoc(resource.data.orderId).data.customerId == request.auth.uid ||
        shopDoc(orderDoc(resource.data.orderId).data.shopId).data.ownerId == request.auth.uid
      );
      allow create: if isCustomer() &&
        orderDoc(request.resource.data.orderId).data.customerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
