# Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=replace-me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-me.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
NEXT_PUBLIC_FIREBASE_APP_ID=replace-me

# Public app URL for QR codes and share links
NEXT_PUBLIC_APP_URL=https://snapcopy-gules.vercel.app/

# Firebase Admin config for secure server verification
FIREBASE_CLIENT_EMAIL=replace-me@replace-me.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
ADMIN_EMAILS=admin@example.com

# AWS S3 config
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=replace-me
AWS_S3_ENDPOINT=

# Razorpay platform payment config
# TODO(security): rotate any Razorpay live credentials that were previously committed here.
# Example files must contain placeholders only.
RAZORPAY_KEY_ID=replace-me
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me
NEXT_PUBLIC_RAZORPAY_KEY_ID=$RAZORPAY_KEY_ID
RAZORPAY_ROUTE_BUSINESS_CATEGORY=replace-with-valid-razorpay-category
RAZORPAY_ROUTE_BUSINESS_SUBCATEGORY=replace-with-valid-razorpay-subcategory
PLATFORM_TRANSACTION_FEE_PAISE=100
PLATFORM_SHOP_CREATION_FEE_PAISE=4900
RAZORPAY_ESTIMATED_FEE_PERCENT=2
RAZORPAY_ESTIMATED_GST_PERCENT=18
